{
  "name": "pharos-safetx",
  "version": "0.1.0",
  "description": "Portable AI x RealFi pre-signing transaction firewall Skill for AI agents before signing Pharos/EVM transactions.",
  "license": "MIT",
  "runtime": {
    "node": ">=20"
  },
  "schemas": {
    "request": "schemas/safetx-request.schema.json",
    "result": "schemas/safetx-result.schema.json"
  },
  "assets": {
    "networks": "assets/networks.json",
    "tokens": "assets/tokens.json",
    "riskSelectors": "assets/risk-selectors.json",
    "erc20Reference": "assets/erc20/StandardERC20.sol"
  },
  "references": {
    "query": "references/query.md",
    "transaction": "references/transaction.md",
    "contract": "references/contract.md",
    "safetx": "references/safetx.md"
  },
  "interfaces": {
    "cli": {
      "command": "npm run analyze -- <request.json>",
      "example": "npm run analyze -- examples/warn-infinite-approval.json"
    },
    "init": {
      "command": "npm run init -- --target <target>",
      "targets": [
        "all",
        "codex"
      ],
      "output": "dist/agent-deploy"
    }
  },
  "decisions": {
    "ALLOW": "The agent may proceed if the user session permits autonomous signing.",
    "WARN": "The agent should pause and ask the user for explicit confirmation.",
    "BLOCK": "The agent must not sign or submit the transaction."
  }
}
