{
  "openapi": "3.1.0",
  "info": {
    "title": "Pharos SafeTx API",
    "version": "0.1.0",
    "description": "Pre-signing transaction safety analysis for AI x RealFi agents."
  },
  "servers": [
    {
      "url": "https://YOUR-SAFETX-HOST.example.com",
      "description": "Replace with your deployed SafeTx HTTPS endpoint."
    }
  ],
  "paths": {
    "/analyze": {
      "post": {
        "operationId": "analyzeTransaction",
        "summary": "Analyze a proposed Pharos/EVM transaction before signing.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SafeTxRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SafeTx decision and findings.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SafeTxResult"
                }
              }
            }
          }
        }
      }
    },
    "/explain": {
      "post": {
        "operationId": "explainRisk",
        "summary": "Explain SafeTx risk findings.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SafeTxRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Compact risk explanation."
          }
        }
      }
    },
    "/suggest": {
      "post": {
        "operationId": "suggestSafeAction",
        "summary": "Suggest the safest next action for the agent.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SafeTxRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent action and safer alternative."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SafeTxRequest": {
        "title": "SafeTxRequest",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "user_intent",
          "chainId",
          "from",
          "to"
        ],
        "properties": {
          "user_intent": {
            "type": "string",
            "minLength": 1,
            "description": "Natural-language instruction the agent is trying to satisfy."
          },
          "chainId": {
            "type": "integer",
            "minimum": 1,
            "description": "Target EVM chain id."
          },
          "from": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]{40}$",
            "description": "Wallet or agent address initiating the transaction."
          },
          "to": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]{40}$",
            "description": "Transaction target contract or recipient."
          },
          "value": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]+$",
            "default": "0x0",
            "description": "Native value as an EVM hex quantity."
          },
          "calldata": {
            "type": "string",
            "pattern": "^0x([a-fA-F0-9]{2})*$",
            "default": "0x",
            "description": "Transaction calldata as byte-aligned hex."
          },
          "language": {
            "type": "string",
            "enum": [
              "en",
              "zh",
              "zh-CN",
              "bilingual"
            ],
            "default": "en",
            "description": "Output language for findings, reasons, agent action, and safer alternative."
          },
          "trustedSpenders": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]{40}$"
            },
            "default": []
          },
          "blockedAddresses": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]{40}$"
            },
            "default": []
          },
          "addressBook": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]{40}$"
            },
            "default": {}
          },
          "tokenDecimals": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0,
              "maximum": 36
            },
            "default": {},
            "description": "Optional token decimals by symbol or token address, used to compare human intent amounts with ERC20 base-unit calldata."
          },
          "policy": {
            "type": "object",
            "additionalProperties": false,
            "description": "Optional per-request agent policy for whitelists and transaction limits.",
            "properties": {
              "allowedTargets": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^0x[a-fA-F0-9]{40}$"
                },
                "default": []
              },
              "allowedRecipients": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^0x[a-fA-F0-9]{40}$"
                },
                "default": []
              },
              "allowedSpenders": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^0x[a-fA-F0-9]{40}$"
                },
                "default": []
              },
              "maxNativeValue": {
                "type": "string",
                "pattern": "^0x[a-fA-F0-9]+$",
                "description": "Maximum native token value as an EVM hex quantity."
              },
              "maxTokenAmounts": {
                "type": "object",
                "additionalProperties": {
                  "type": "string",
                  "pattern": "^\\d+(\\.\\d+)?$"
                },
                "description": "Maximum token amounts by symbol or token address, expressed in human units when tokenDecimals is provided."
              }
            }
          }
        }
      },
      "SafeTxResult": {
        "title": "SafeTxResult",
        "type": "object",
        "required": [
          "decision",
          "risk_score",
          "intent",
          "transaction",
          "findings",
          "reasons",
          "agent_action",
          "safer_alternative"
        ],
        "properties": {
          "decision": {
            "type": "string",
            "enum": [
              "ALLOW",
              "WARN",
              "BLOCK"
            ]
          },
          "risk_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "intent": {
            "type": "object"
          },
          "transaction": {
            "type": "object"
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "severity",
                "code",
                "message",
                "score"
              ],
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high",
                    "critical"
                  ]
                },
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "score": {
                  "type": "integer"
                }
              }
            }
          },
          "reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "agent_action": {
            "type": "string"
          },
          "safer_alternative": {
            "type": "string"
          }
        }
      }
    }
  }
}
